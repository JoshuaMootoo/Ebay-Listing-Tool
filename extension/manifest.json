{
  "manifest_version": 3,
  "name": "eBay Bulk Listing Tool",
  "version": "1.2.0",
  "description": "Bulk-add variations and auto-upload images to eBay listings.",
  "permissions": ["activeTab", "scripting", "webNavigation"],
  "host_permissions": ["https://*.ebay.com/*", "https://*.ebay.co.uk/*", "https://*.ebay.com.au/*", "https://*.ebay.de/*", "https://*.ebay.fr/*", "https://*.ebay.it/*", "https://*.ebay.es/*", "https://*.ebay.ca/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "eBay Bulk Listing Tool"
  },
  "content_scripts": [
    {
      "matches": ["https://*.ebay.com/*", "https://*.ebay.co.uk/*", "https://*.ebay.com.au/*", "https://*.ebay.de/*", "https://*.ebay.fr/*", "https://*.ebay.it/*", "https://*.ebay.es/*", "https://*.ebay.ca/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
